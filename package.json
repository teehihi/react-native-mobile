{
  "name": "dac-san-viet-ui",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node scripts/auto-ip.js && expo start",
    "start:clear": "node scripts/auto-ip.js && expo start --clear",
    "start:dev": "node scripts/auto-ip.js && expo start --dev-client",
    "android": "node scripts/auto-ip.js && expo start --android",
    "android:dev": "node scripts/auto-ip.js && expo run:android",
    "ios": "node scripts/auto-ip.js && expo start --ios",
    "ios:dev": "node scripts/auto-ip.js && expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "web": "expo start --web",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'TypeScript check passed!'",
    "test-api": "node test-api-connection.js",
    "test-ios": "node test-ios-connection.js",
    "test-real-device": "node test-real-device.js",
    "update-ip": "node scripts/update-ip.js",
    "auto-ip": "node scripts/auto-ip.js",
    "setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')) fs.copyFileSync('.env.example', '.env')\" && npm run auto-ip"
  },
  "dependencies": {
    "@callstack/liquid-glass": "^0.7.1",
    "@expo/ui": "~55.0.12",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/material-top-tabs": "^7.4.23",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/stack": "^7.6.16",
    "@realm/react": "^0.20.0",
    "axios": "^1.13.2",
    "babel-preset-expo": "~55.0.8",
    "d3-shape": "^3.2.0",
    "expo": "~55.0.17",
    "expo-blur": "^55.0.14",
    "expo-build-properties": "^55.0.13",
    "expo-dev-client": "^55.0.28",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "^55.0.14",
    "expo-image-picker": "~55.0.19",
    "expo-linear-gradient": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-notifications": "~55.0.20",
    "expo-status-bar": "~55.0.5",
    "nativewind": "^4.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-dotenv": "^3.4.11",
    "react-native-pager-view": "8.0.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "react-native-worklets-core": "^1.6.3",
    "realm": "^20.2.0",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "@types/react-native-dotenv": "^0.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
